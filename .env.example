# Database configuration
DATABASE_URL=sqlite://mudl.db

# Default player ID used during bootstrap to place the player in the starting location of the default world.
DEFAULT_PLAYER=player:admin-001

# MUDL module directory (contains universe.mudl). Override to use a custom universe pack.
MUDL_MODULE=modules/default

# Optional: path directly to universe.mudl (overrides MUDL_MODULE/universe.mudl)
# MUDL_UNIVERSE=modules/default/universe.mudl

RUST_LOG=info
