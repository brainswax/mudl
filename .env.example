# Database configuration
DATABASE_URL=sqlite://mudl.db

# Default player ID used during bootstrap to place the player in the starting location of the default world.
DEFAULT_PLAYER=player:admin-001

# MUDL module directory (contains universe.mudl). Override to use a custom universe pack.
MUDL_MODULE=modules/default

# Optional: path directly to universe.mudl (overrides MUDL_MODULE/universe.mudl)
# MUDL_UNIVERSE=modules/default/universe.mudl

RUST_LOG=info

# IRC bot (cargo run --bin irc) — IRCv3 over TLS by default
IRC_SERVER=irc.libera.chat
IRC_PORT=6697
IRC_TLS=true
IRC_IRCV3=true
IRC_BOT_NICK=mudl
IRC_REALNAME=MUDL Bot
IRC_WORLD_CHANNEL=#mudl
IRC_ROOM_CHANNEL_PREFIX=#mudl-
# IRC_MOCK=1            # stdin mock mode for local testing (no TLS/network)
# IRC_TLS=false         # plaintext dev only (use IRC_PORT=6667)
# IRC_IRCV3=false       # disable CAP negotiation on legacy servers
# IRC_CONNECT_TIMEOUT=30
# IRC_READ_TIMEOUT=120
# IRC_REGISTRATION_TIMEOUT=90

# Login authentication (SEC-01) — required on live IRC; disabled when IRC_MOCK is set
# MUDL_LOGIN_REQUIRE_AUTH=true
# MUDL_LOGIN_TOKENS=player:hero-001=change-me,player:admin-001=wizard-secret
# MUDL_LOGIN_IDENTITY_BINDINGS=alice=player:hero-001,bob=player:hero-002

# IRC identity verification (SEC-03) — optional; requires IRCv3 account-tag from server
# IRC_REQUIRE_ACCOUNT_TAG=true
# MUDL_IRC_ACCOUNT_BINDINGS=alice=LiberaAccountName

# NickServ — register the account once in your IRC client, then set password here for auto-IDENTIFY
#   /msg NickServ REGISTER <password> <email>   (one-time, from any client using that nick)
# IRC_NICKSERV_SERVICE=NickServ
# IRC_NICKSERV_ACCOUNT=muddlebot               # registered NickServ account (required when IRC_BOT_NICK differs)
# IRC_NICKSERV_PASSWORD='bot-account-secret'   # quote if password contains $ or #

# Slack bot (cargo run --bin slack) — group play via Event Subscriptions
# Full setup: docs/SLACK.md  |  App manifest: slack-app-manifest.yaml
# Smoke test: make test-slack-flow  (no credentials)
#
# --- Live workspace (required) ---
# SLACK_BOT_TOKEN=xoxb-your-bot-token          # OAuth & Permissions → Install App
# SLACK_SIGNING_SECRET=your-signing-secret     # Basic Information → Signing Secret
#
# --- Recommended for group play ---
# SLACK_APP_ID=A0123456789                      # strips <@APP> mentions in DMs
# SLACK_WORLD_CHANNEL=C0123456789              # #mudl-ooc channel id (invite bot)
# SLACK_BIND_ADDR=0.0.0.0:3000
# SLACK_EVENTS_PATH=/slack/events              # Event Subscriptions Request URL path
#
# --- In-character routing (pick one) ---
# Default: per-room channels mudl-<slug> (bot uses channels:join)
# SLACK_ROOM_CHANNEL_PREFIX=mudl-
# Threaded: all IC speech in one channel's threads
# SLACK_ROOMS_CHANNEL=C0123456789
#
# --- Local testing (no HTTPS / no Slack API) ---
# SLACK_MOCK=1                                  # stdin: user_id channel_id command
#
# --- Secured group playtest (see SECURITY.md SEC-01) ---
# MUDL_LOGIN_REQUIRE_AUTH=true
# MUDL_LOGIN_TOKENS=player:hero-001=change-me,player:hero-002=other-secret
# MUDL_LOGIN_IDENTITY_BINDINGS=U01234ABC=player:hero-001,U05678DEF=player:hero-002